{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://pg-finder-api-ls11.onrender.com/api",
        "EXPO_PUBLIC_USE_BACKEND": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://pg-finder-api-ls11.onrender.com/api",
        "EXPO_PUBLIC_USE_BACKEND": "true"
      }
    }
  }
}
