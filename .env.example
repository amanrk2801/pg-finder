# Expo app configuration (values are baked into the app at build time)
# Base URL of the backend API, reachable from your device/emulator.
# Use your machine's LAN IP when testing on a physical device.
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.100:4000/api
EXPO_PUBLIC_USE_BACKEND=true

# Local superadmin bypass (development only — never ship real credentials)
EXPO_PUBLIC_SUPER_ADMIN_EMAIL=admin@example.com
EXPO_PUBLIC_SUPER_ADMIN_PASSWORD=change-me
